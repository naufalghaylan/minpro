generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(255)
  username     String    @unique @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  password     String    @db.VarChar(500)
  bio          String?   @db.VarChar(500)
  role         RoleType
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  referralCode String    @unique @db.VarChar(50)
  referredBy   String?
  referredByUser User?   @relation("UserReferral", fields: [referredBy], references: [id])
  referrals    User[]    @relation("UserReferral")
  events       events[]
  orders       orders[]
  wallets      wallets?

  @@map("users")
}

model event_images {
  id      String @id
  eventId String
  url     String
  events  events @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model events {
  id               String         @id
  name             String         @unique @db.VarChar(255)
  price            Float
  totalSeats       Int
  availableSeats   Int
  eventOrganizerId String

  created_at       DateTime       @default(now())
  deleted_at       DateTime?
  updated_at       DateTime
  event_images     event_images[]
  users            User           @relation(fields: [eventOrganizerId], references: [id])
  orders           orders[]
}

model orders {
  id          String      @id
  customerId  String
  eventId     String
  quantity    Int
  totalAmount Float
  status      StatusOrder @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  users       User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events      events      @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model wallets {
  id      String @id
  userId  String @unique
  balance Float
  users   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RoleType {
  CUSTOMER
  EVENT_ORGANIZER
}

enum StatusOrder {
  PENDING
  REJECTED
  CANCELLED
  EXPIRED
  DONE
  PAID
}
