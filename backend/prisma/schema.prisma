generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(255)
  username     String    @unique @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  password     String    @db.VarChar(500)
  bio          String?   @db.VarChar(500)
  role         RoleType
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  referralCode String    @unique @db.VarChar(50)
  referredBy   String?
  events       events[]
  orders       orders[]
  users        User?     @relation("usersTousers", fields: [referredBy], references: [id])
  other_users  User[]    @relation("usersTousers")
  wallets      wallets?
  coupons      coupons[]

  @@index([referredBy])
  @@map("users")
}

model events {
  id               String         @id @default(uuid())
  name             String         @unique @db.VarChar(255)
  price            Float
  totalSeats       Int
  availableSeats   Int
  eventOrganizerId String
  created_at       DateTime       @default(now())
  deleted_at       DateTime?
  updated_at       DateTime       @updatedAt
  event_images     event_images[]
  users            User           @relation(fields: [eventOrganizerId], references: [id])
  orders           orders[]
}

model event_images {
  id      String @id @default(uuid())
  eventId String
  url     String
  events  events @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model orders {
  id          String      @id  @default(uuid())
  customerId  String
  eventId     String
  quantity    Int
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  event       events      @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model wallets {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model coupons {
  id        String       @id @default(uuid())
  userId    String
  code      String?      @unique @db.VarChar(50)
  source    CouponSource
  amount    Int
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("coupons")
}

enum RoleType {
  CUSTOMER
  EVENT_ORGANIZER
}

enum StatusOrder {
  PENDING
  REJECTED
  CANCELLED
  EXPIRED
  DONE
  PAID
}

enum CouponSource {
  REFERRAL_SIGNUP
  EVENT_PROMOTION
  ORDER_REFUND
  MANUAL_GRANT
}
