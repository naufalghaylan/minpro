{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
  },
  "include": ["index.ts", "prisma.config.ts", "src/**/*.ts", "src/**/*.d.ts"],
  "include": ["index.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}