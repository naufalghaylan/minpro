          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/organizer/dashboard/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizer",
                "dashboard",
                "overview"
              ]
