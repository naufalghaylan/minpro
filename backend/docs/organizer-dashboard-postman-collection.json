            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Anime Fest 2026 Updated\",\n  \"price\": 275000,\n  \"totalSeats\": 650,\n  \"city\": \"Jakarta\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 10,\n  \"discountStart\": \"2026-05-01T00:00:00.000Z\",\n  \"discountEnd\": \"2026-05-10T23:59:59.000Z\"\n}"
